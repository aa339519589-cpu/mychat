NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

DEEPSEEK_API_KEY=
MIMO_API_KEY=
TAVILY_API_KEY=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AGENT_PUBLIC_URL=http://localhost:3000

# At least 32 random characters. Also encrypts saved custom model API keys.
AGENT_CREDENTIAL_KEY=

E2B_API_KEY=
E2B_TEMPLATE=

# Self-hosted production only. Comma-separated exact private hosts or host:port pairs.
# MODEL_ENDPOINT_PRIVATE_ALLOWLIST=192.168.1.20:8080

OPENAI_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=

# 「深度」档位 / 深度研究：OpenAI 兼容反代（如 Grok 4.5）。两者都填才启用，否则回退 DeepSeek V4 Pro。
# DEEP_TIER_BASE_URL=https://your-proxy.example/v1
# DEEP_TIER_API_KEY=
# DEEP_TIER_MODEL=grok-4
# DEEP_TIER_AUTH_TYPE=bearer

# Grok 4.5 reasoning intensity for 「深度」档: low | medium | high (default low). deepResearch forces high.
# DEEP_TIER_REASONING_EFFORT=low


# Platform image (same reverse proxy). OpenAI-compatible /v1/images/generations
# Top tier: grok-imagine-image-quality ($0.05/image)
# DEEP_TIER_IMAGE_MODEL=grok-imagine-image-quality

# Platform video (same reverse proxy). POST /videos/generations → poll GET /videos/{id}
# Top tier: grok-imagine-video-1.5 ($0.08/sec). Duration left to API default (no frontend picker).
# DEEP_TIER_VIDEO_MODEL=grok-imagine-video-1.5

