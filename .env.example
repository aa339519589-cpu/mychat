NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

DEEPSEEK_API_KEY=
MIMO_API_KEY=
TAVILY_API_KEY=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AGENT_PUBLIC_URL=http://localhost:3000

# At least 32 random characters. Also encrypts saved custom model API keys.
AGENT_CREDENTIAL_KEY=

E2B_API_KEY=
E2B_TEMPLATE=

# Self-hosted production only. Comma-separated exact private hosts or host:port pairs.
# MODEL_ENDPOINT_PRIVATE_ALLOWLIST=192.168.1.20:8080

OPENAI_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=

# 「深度」档位 / 深度研究：OpenAI 兼容反代（如 Grok 4.5）。两者都填才启用，否则回退 DeepSeek V4 Pro。
# 不要把临时 ngrok 地址用于生产；隧道停止后会返回 ERR_NGROK_3200。
# DEEP_TIER_BASE_URL=https://your-stable-proxy.example/v1
# DEEP_TIER_API_KEY=
# DEEP_TIER_MODEL=grok-4
# DEEP_TIER_AUTH_TYPE=bearer

# Grok 4.5 reasoning intensity for 「深度」档: low | medium | high (default low). deepResearch forces high.
# DEEP_TIER_REASONING_EFFORT=low

# Platform image. Media-specific transport overrides the shared deep-tier transport,
# so image generation can use a stable endpoint even when chat uses another proxy.
# Missing values fall back to DEEP_TIER_BASE_URL / API_KEY / AUTH_TYPE.
# DEEP_TIER_IMAGE_BASE_URL=https://your-stable-media-proxy.example/v1
# DEEP_TIER_IMAGE_API_KEY=
# DEEP_TIER_IMAGE_AUTH_TYPE=bearer
# DEEP_TIER_IMAGE_MODEL=grok-imagine-image-quality

# Platform video. POST /videos/generations → poll GET /videos/{id}.
# Missing values fall back to DEEP_TIER_BASE_URL / API_KEY / AUTH_TYPE.
# DEEP_TIER_VIDEO_BASE_URL=https://your-stable-media-proxy.example/v1
# DEEP_TIER_VIDEO_API_KEY=
# DEEP_TIER_VIDEO_AUTH_TYPE=bearer
# DEEP_TIER_VIDEO_MODEL=grok-imagine-video-1.5

# Temporary release gate used to drain chat generations before lease migrations.
GENERATION_MAINTENANCE_MODE=false
