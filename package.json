{
  "name": "mychat",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "patch:seedream": "node scripts/patch-seedream-image-size.mjs",
    "postinstall": "npm run patch:seedream",
    "predev": "npm run patch:seedream",
    "dev": "next dev",
    "prebuild": "npm run patch:seedream",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 164 app components e2e lib proxy.ts playwright.config.ts next.config.mjs postcss.config.mjs eslint.config.mjs scripts tests",
    "precheck": "npm run patch:seedream",
    "check": "tsc --noEmit --incremental false --noUnusedLocals --noUnusedParameters",
    "architecture": "node scripts/check-architecture.mjs",
    "pretest": "npm run patch:seedream",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --coverage",
    "test:migrations": "bash scripts/verify-generation-migrations-pg16.sh",
    "test:e2e": "playwright test",
    "quality": "npm run architecture && npm run check && npm run lint && npm run test:coverage",
    "verify": "npm run quality && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "1.6.1",
    "clsx": "^2.1.1",
    "e2b": "^2.30.5",
    "function-plot": "^1.25.4",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "pdfjs-dist": "^6.0.227",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5",
    "shadcn": "^4.8.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "5.7.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
