{
  "name": "mychat",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prestart": "tsx scripts/assert-production-config.ts",
    "start": "tsx scripts/start-production.ts",
    "worker": "tsx job-worker.ts",
    "outbox:redrive": "node scripts/redrive-outbox.mjs",
    "ops:load": "node ops/load/run.mjs",
    "ops:chaos": "node ops/chaos/run.mjs",
    "ops:soak": "node ops/soak/run.mjs",
    "lint": "eslint --max-warnings 0 app components e2e lib ops proxy.ts playwright.config.ts next.config.mjs postcss.config.mjs eslint.config.mjs scripts tests",
    "lint:backend": "eslint --max-warnings 0 app/api lib/agent lib/api lib/chat lib/code-agent lib/code-tools lib/generation lib/jobs lib/llm lib/observability lib/supabase lib/tools job-worker.ts scripts lib/github.ts lib/quota.ts lib/model-endpoint-server.ts lib/model-endpoint-secret.ts lib/rate-limit.ts",
    "check": "tsc --noEmit --incremental false --noUnusedLocals --noUnusedParameters",
    "architecture": "node scripts/check-architecture.mjs",
    "complexity": "node scripts/check-function-complexity.mjs",
    "complexity:baseline": "node scripts/check-function-complexity.mjs --print-baseline",
    "migration:contract": "node scripts/check-migration-contract.mjs",
    "database:types:generate": "bash scripts/verify-database-types-pg16.sh --write",
    "database:types:check": "bash scripts/verify-database-types-pg16.sh --check",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --coverage",
    "test:migrations": "bash scripts/verify-generation-migrations-pg16.sh",
    "test:e2e": "playwright test",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "quality": "npm run architecture && npm run complexity && npm run migration:contract && npm run check && npm run lint:backend && npm run lint && npm run test:coverage",
    "verify": "npm run quality && npm run audit:prod && npm run database:types:check && npm run test:migrations && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "1.6.1",
    "clsx": "^2.1.1",
    "e2b": "^2.30.5",
    "function-plot": "^1.25.4",
    "isomorphic-dompurify": "^3.18.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "motion": "12.42.2",
    "next": "16.2.6",
    "pdfjs-dist": "^6.0.227",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
