{
  "annotations": {
    "list": []
  },
  "description": "Database-authoritative MyChat job control-plane, worker fleet, billing reconciliation, SLO, lease recovery, and outbox health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "text": "NOT READY" },
                "1": { "color": "green", "text": "READY" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_worker_fleet_ready", "legendFormat": "fleet", "range": true, "refId": "A" }
      ],
      "title": "Worker Fleet Readiness",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_worker_fleet_active_workers", "legendFormat": "workers", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "mychat_authoritative_worker_fleet_total_capacity", "legendFormat": "capacity", "range": true, "refId": "B" }
      ],
      "title": "Fresh Workers / Capacity",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_worker_fleet_stale_workers", "legendFormat": "stale", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "mychat_authoritative_worker_fleet_draining_workers", "legendFormat": "draining", "range": true, "refId": "B" }
      ],
      "title": "Stale / Draining Workers",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 15 }, { "color": "red", "value": 20 }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "max({__name__=~\"mychat_authoritative_snapshot_age_seconds|mychat_authoritative_worker_fleet_snapshot_age_seconds\"})", "legendFormat": "snapshot age", "range": true, "refId": "A" }
      ],
      "title": "Metrics Snapshot Age",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2, "showPoints": "never" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 5,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_worker_queue_freshest_heartbeat_age_seconds", "legendFormat": "{{queue}}", "range": true, "refId": "A" }
      ],
      "title": "Worker Heartbeat Freshness by Queue",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "max by (job_type) (mychat_authoritative_queue_oldest_age_seconds)", "legendFormat": "{{job_type}}", "range": true, "refId": "A" }
      ],
      "title": "Oldest Queued Job",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 1, "showPoints": "never", "stacking": { "group": "A", "mode": "normal" } }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "id": 7,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum by (job_type) (mychat_authoritative_queue_depth)", "legendFormat": "{{job_type}}", "range": true, "refId": "A" }
      ],
      "title": "Durable Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 8,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum by (status) (mychat_authoritative_jobs_terminal_window)", "legendFormat": "{{status}}", "range": true, "refId": "A" }
      ],
      "title": "One-hour Terminal Outcomes",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "min": 0, "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "id": 9,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum by (objective) (mychat_authoritative_slo_window_good) / clamp_min(sum by (objective) (mychat_authoritative_slo_window_eligible), 1)", "legendFormat": "{{objective}}", "range": true, "refId": "A" }
      ],
      "title": "Job and Cancellation SLO",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "id": 10,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "sum by (job_type) (mychat_authoritative_job_lease_expired)", "legendFormat": "expired {{job_type}}", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum by (job_type) (mychat_authoritative_job_retry_waiting)", "legendFormat": "retry {{job_type}}", "range": true, "refId": "B" }
      ],
      "title": "Lease Recovery / Retry Waiting",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2, "showPoints": "never" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 11,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_outbox_pending", "legendFormat": "pending", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "mychat_authoritative_outbox_retrying", "legendFormat": "retrying", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "mychat_authoritative_outbox_expired_leases", "legendFormat": "expired locks", "range": true, "refId": "C" },
        { "editorMode": "code", "expr": "mychat_authoritative_outbox_dead", "legendFormat": "dead", "range": true, "refId": "D" }
      ],
      "title": "Transactional Outbox",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "id": 12,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_outbox_oldest_ready_age_seconds", "legendFormat": "oldest ready", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "mychat_authoritative_worker_queue_total_capacity", "legendFormat": "capacity {{queue}}", "range": true, "refId": "B" }
      ],
      "title": "Outbox Age / Queue Capacity",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "color": "red", "text": "BLOCKED" }, "1": { "color": "green", "text": "READY" } }, "type": "value" }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_billing_release_ready", "legendFormat": "billing", "range": true, "refId": "A" }
      ],
      "title": "Billing Release Gate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2, "showPoints": "never" }, "min": 0, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 28 },
      "id": 14,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_billing_mismatches_total", "legendFormat": "mismatches", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "mychat_authoritative_billing_release_blockers", "legendFormat": "release blockers", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "mychat_authoritative_billing_active_legacy_jobs", "legendFormat": "active legacy jobs", "range": true, "refId": "C" }
      ],
      "title": "Billing Reconciliation Blockers",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "min": 0, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 28 },
      "id": 15,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "editorMode": "code", "expr": "mychat_authoritative_billing_snapshot_age_seconds", "legendFormat": "snapshot age seconds", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "mychat_authoritative_billing_held_balance_tokens", "legendFormat": "held balance tokens", "range": true, "refId": "B" }
      ],
      "title": "Billing Snapshot / Held Balance",
      "type": "timeseries"
    }
  ],
